<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jtcool.wms.mapper.WmsAreaMapper">

    <resultMap id="WmsAreaResult" type="com.jtcool.wms.domain.WmsArea">
        <id property="areaId" column="area_id"/>
        <result property="warehouseId" column="warehouse_id"/>
        <result property="areaCode" column="area_code"/>
        <result property="areaName" column="area_name"/>
        <result property="status" column="status"/>
        <result property="delFlag" column="del_flag"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectWmsAreaVo">
        select area_id, warehouse_id, area_code, area_name, status, del_flag,
               create_by, create_time, update_by, update_time, remark
        from wms_area
    </sql>

    <select id="selectWmsAreaList" resultMap="WmsAreaResult">
        <include refid="selectWmsAreaVo"/>
        <where>
            del_flag = '0'
            <if test="warehouseId != null">and warehouse_id = #{warehouseId}</if>
            <if test="areaName != null and areaName != ''">and area_name like concat('%', #{areaName}, '%')</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
    </select>

    <select id="selectWmsAreaById" resultMap="WmsAreaResult">
        <include refid="selectWmsAreaVo"/>
        where area_id = #{areaId} and del_flag = '0'
    </select>

    <select id="selectWmsAreaByWarehouseId" resultMap="WmsAreaResult">
        <include refid="selectWmsAreaVo"/>
        where warehouse_id = #{warehouseId} and del_flag = '0' and status = '0'
    </select>

    <insert id="insertWmsArea" useGeneratedKeys="true" keyProperty="areaId">
        insert into wms_area(warehouse_id, area_code, area_name, status, create_by, create_time, remark)
        values(#{warehouseId}, #{areaCode}, #{areaName}, #{status}, #{createBy}, now(), #{remark})
    </insert>

    <update id="updateWmsArea">
        update wms_area
        <set>
            <if test="areaName != null">area_name = #{areaName},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = now(),
            <if test="remark != null">remark = #{remark},</if>
        </set>
        where area_id = #{areaId}
    </update>

    <update id="deleteWmsAreaByIds">
        update wms_area set del_flag = '2' where area_id in
        <foreach collection="array" item="areaId" open="(" separator="," close=")">#{areaId}</foreach>
    </update>

</mapper>
