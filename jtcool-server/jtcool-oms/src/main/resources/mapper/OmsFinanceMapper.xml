<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jtcool.oms.mapper.OmsFinanceMapper">

    <resultMap type="com.jtcool.oms.domain.OmsFinance" id="OmsFinanceResult">
        <result property="financeId" column="finance_id"/>
        <result property="orderId" column="order_id"/>
        <result property="financeType" column="finance_type"/>
        <result property="totalAmount" column="total_amount"/>
        <result property="paidAmount" column="paid_amount"/>
        <result property="unpaidAmount" column="unpaid_amount"/>
        <result property="paymentStatus" column="payment_status"/>
        <result property="invoiceStatus" column="invoice_status"/>
        <result property="invoiceNo" column="invoice_no"/>
        <result property="invoiceDate" column="invoice_date"/>
        <result property="invoiceAmount" column="invoice_amount"/>
        <result property="delFlag" column="del_flag"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectOmsFinanceVo">
        select finance_id, order_id, finance_type, total_amount, paid_amount, unpaid_amount, payment_status,
        invoice_status, invoice_no, invoice_date, invoice_amount, del_flag, create_by, create_time, update_by, update_time, remark
        from oms_finance
    </sql>

    <select id="selectOmsFinanceList" parameterType="com.jtcool.oms.domain.OmsFinance" resultMap="OmsFinanceResult">
        <include refid="selectOmsFinanceVo"/>
        <where>
            del_flag = '0'
            <if test="orderId != null">AND order_id = #{orderId}</if>
            <if test="financeType != null and financeType != ''">AND finance_type = #{financeType}</if>
            <if test="paymentStatus != null and paymentStatus != ''">AND payment_status = #{paymentStatus}</if>
            <if test="invoiceStatus != null and invoiceStatus != ''">AND invoice_status = #{invoiceStatus}</if>
        </where>
    </select>

    <select id="selectOmsFinanceById" parameterType="Long" resultMap="OmsFinanceResult">
        <include refid="selectOmsFinanceVo"/> where finance_id = #{financeId}
    </select>

    <select id="selectOmsFinanceByOrderId" parameterType="Long" resultMap="OmsFinanceResult">
        <include refid="selectOmsFinanceVo"/> where order_id = #{orderId} and del_flag = '0' limit 1
    </select>

    <insert id="insertOmsFinance" parameterType="com.jtcool.oms.domain.OmsFinance" useGeneratedKeys="true" keyProperty="financeId">
        insert into oms_finance(order_id, finance_type, total_amount, paid_amount, unpaid_amount, payment_status, invoice_status, create_by, create_time, remark)
        values(#{orderId}, #{financeType}, #{totalAmount}, 0, #{totalAmount}, 'UNPAID', 'NOT_ISSUED', #{createBy}, CURRENT_TIMESTAMP, #{remark})
    </insert>

    <update id="updateOmsFinance" parameterType="com.jtcool.oms.domain.OmsFinance">
        update oms_finance
        <set>
            <if test="paidAmount != null">paid_amount = #{paidAmount},</if>
            <if test="unpaidAmount != null">unpaid_amount = #{unpaidAmount},</if>
            <if test="paymentStatus != null">payment_status = #{paymentStatus},</if>
            <if test="invoiceStatus != null">invoice_status = #{invoiceStatus},</if>
            <if test="invoiceNo != null">invoice_no = #{invoiceNo},</if>
            <if test="invoiceDate != null">invoice_date = #{invoiceDate},</if>
            <if test="invoiceAmount != null">invoice_amount = #{invoiceAmount},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = CURRENT_TIMESTAMP,
        </set>
        where finance_id = #{financeId}
    </update>

</mapper>
